{
  "framework": "vite",
  "buildCommand": "cd Mern-Form && npm run build",
  "outputDirectory": "Mern-Form/dist",
  "installCommand": "npm install --prefix backend && npm install --prefix Mern-Form",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
